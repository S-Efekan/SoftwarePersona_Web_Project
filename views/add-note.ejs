<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <link rel="stylesheet" href="/css/add-note.css"> <title>Yeni Not Ekle</title>
</head>
<body>
    <div class="form-container">
        <form action="/notes/add" method="post" class="retro-form">
            <h2>YENİ NOT</h2>
            <input type="text" name="title" placeholder="BAŞLIK" required>
            <textarea name="content" placeholder="NOT İÇERİĞİ" required></textarea> <input type="text" name="category" placeholder="KATEGORİ">
            <select name="status"> <option value="Çalışılacak">Çalışılacak</option>
                <option value="Tamamlandı">Tamamlandı</option>
                <option value="Önemli">Önemli</option>
            </select>
            <button type="submit" class="submit-btn">KAYDET</button>
            <a href="/notes/dashboard" class="back-btn">İPTAL</a> </form>
    </div>
</body>
</html>